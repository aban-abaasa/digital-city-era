# ============================================================================
# DIGITAL CITY ERA - FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================================
# This file is for FRONTEND ONLY (React/Vite application)
# Client-side variables - can be exposed to browser
# All variables must start with VITE_ prefix for Vite to expose them
# ============================================================================

# ====== SUPABASE DATABASE CONFIGURATION (Frontend Only) ======
# Frontend uses ANON_KEY for client-side operations
# This is the SAME Supabase instance used by ICAN Capital Engine
# VITE_ prefix is required for Vite to expose to browser
VITE_SUPABASE_URL=https://hswxazpxcgtqbxeqcxxw.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imhzd3hhenB4Y2d0cWJ4ZXFjeHh3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTIxNDE1NzAsImV4cCI6MjA2NzcxNzU3MH0.ryOHQGgiEFf25Q9XA2K0akCcrQ7NcZddVfnWMdAH0DU

# ====== API CONFIGURATION ======
# Backend API endpoint for frontend to call
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# ====== ENVIRONMENT ======
VITE_ENVIRONMENT=production
VITE_APP_NAME=Digital City Era
VITE_APP_VERSION=2.0.0
VITE_APP_LOGO_URL=https://digitalcity-ug.com/logo.png

# ====== FEATURES ======
# Feature flags for frontend functionality
VITE_ENABLE_BLOCKCHAIN_SYNC=true
VITE_ENABLE_SUPPLIER_APPROVAL=true
VITE_ENABLE_POS_SYSTEM=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_BARCODE_SCANNER=true
VITE_ENABLE_BIOMETRIC=false
VITE_ENABLE_CAMERA=true

# ====== AI CONFIGURATION (Frontend Only) ======
# Gemini AI for product identification and image recognition
VITE_GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
VITE_GEMINI_MODEL=gemini-pro

# ====== BRANDING & UI ======
VITE_BRAND_NAME=Digital City Era
VITE_SUPPORT_EMAIL=support@digitalcity-ug.com
VITE_SUPPORT_PHONE=+256700000000
VITE_COMPANY_WEBSITE=https://digitalcity-ug.com

# ====== MOBILE OPTIMIZATION ======
# Settings for mobile responsiveness and performance
VITE_MOBILE_BREAKPOINT=768
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_SESSION_TIMEOUT=1800000

# ====== CURRENCY & LOCALIZATION ======
VITE_DEFAULT_CURRENCY=UGX
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_TIMEZONE=Africa/Kampala
VITE_DATE_FORMAT=DD/MM/YYYY
VITE_TIME_FORMAT=HH:mm:ss

# ====== PAYMENT METHODS (Frontend Display) ======
VITE_ENABLE_CASH_PAYMENT=true
VITE_ENABLE_MOBILE_MONEY=true
VITE_ENABLE_CARD_PAYMENT=false
VITE_MTN_MERCHANT_CODE=REPLACE_WITH_MTN_CODE
VITE_AIRTEL_MERCHANT_CODE=REPLACE_WITH_AIRTEL_CODE

# ====== ANALYTICS & TRACKING (Frontend Only) ======
# Google Analytics, Mixpanel, etc.
VITE_ANALYTICS_ID=
VITE_TRACKING_ENABLED=false

# ====== ERROR TRACKING (Frontend Only) ======
VITE_SENTRY_DSN=
VITE_ERROR_TRACKING_ENABLED=false

# ====== MAPS & LOCATION ======
VITE_GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_KEY
VITE_ENABLE_LOCATION_TRACKING=true

# ====== CACHE SETTINGS (Frontend Only) ======
# Browser cache control
VITE_CACHE_STRATEGY=network-first
VITE_CACHE_EXPIRY=86400
VITE_STORAGE_KEY_PREFIX=digitalcity_

# ====== DEBUG MODE ======
VITE_DEBUG_MODE=false
VITE_DEBUG_LOGS=false

# ====== BUILD SETTINGS ======
VITE_SOURCE_MAP=false
VITE_BUILD_REPORT=false
